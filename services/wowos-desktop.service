[Unit]
Description=wowOS Desktop Web Server
After=network.target wowos-api.service
Wants=wowos-api.service

[Service]
Type=simple
User=admin
WorkingDirectory=/opt/wowos
Environment=WOWOS_DESKTOP_PORT=9090
ExecStart=/usr/bin/python3 /opt/wowos/ui/desktop_server.py
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
